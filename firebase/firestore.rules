rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: users/{uid} stores role and region
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // manage users from admin console or Cloud Function
    }

    // Financas collection: one doc per ciclo_region (e.g. 2024_norte)
    match /financas/{financeId} {
      allow read: if isAdmin() || isRegionalOwner(resource.data.region);
      allow write: if isAdmin() || isRegionalOwner(request.resource.data.region);
    }

    // fallback
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isRegionalOwner(region) {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.region == region;
    }
  }
}
